---
import { getCollection } from 'astro:content'
import Base from '../layouts/Base.astro'
import { formatDate, readingTime } from '../lib/utils'

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
---

<Base title="stoykotolev.com — Technical Blog">
  <section>
    <h1 class="text-3xl font-bold tracking-tight mb-2">Hi, I'm Stoyko</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-12">Writing about software engineering, tools, and things I find interesting.</p>

    <div class="space-y-10">
      {posts.map(post => (
        <article class="group">
          <a href={`/blog/${post.slug}`} class="block">
            <div class="flex flex-wrap gap-2 mb-2">
              {post.data.tags.map(tag => (
                <span class="text-xs text-blue-600 dark:text-blue-400">#{tag}</span>
              ))}
            </div>
            <h2 class="text-xl font-semibold group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors mb-1">
              {post.data.title}
            </h2>
            <p class="text-gray-500 dark:text-gray-400 text-sm mb-2">{post.data.description}</p>
            <p class="text-xs text-gray-400 dark:text-gray-500">
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              {' · '}{readingTime(post.body)} min read
            </p>
          </a>
        </article>
      ))}
    </div>
  </section>
</Base>
