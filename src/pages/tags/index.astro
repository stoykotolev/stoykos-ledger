---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'

const posts = await getCollection('posts', ({ data }) => !data.draft)
const tagCounts = posts.reduce<Record<string, number>>((acc, post) => {
  for (const tag of post.data.tags) {
    acc[tag] = (acc[tag] ?? 0) + 1
  }
  return acc
}, {})

const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1])
---

<Base title="Tags — stoykotolev.com">
  <h1 class="text-3xl font-bold tracking-tight mb-10">Tags</h1>
  <div class="flex flex-wrap gap-3">
    {tags.map(([tag, count]) => (
      <a
        href={`/tags/${tag}`}
        class="px-3 py-1.5 rounded-full border border-gray-200 dark:border-gray-700 text-sm hover:border-blue-400 dark:hover:border-blue-500 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
      >
        #{tag} <span class="text-gray-400 dark:text-gray-500 text-xs">{count}</span>
      </a>
    ))}
  </div>
</Base>
